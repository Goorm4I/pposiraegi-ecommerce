# 로컬 개발 시 mock 사용 여부 (true: 목업, false: 실제 API)
REACT_APP_USE_MOCK=false

# 백엔드 API URL (로컬: http://localhost:8080, 배포: CloudFront URL)
REACT_APP_API_URL=http://localhost:8080

# WebSocket URL
REACT_APP_WS_URL=ws://localhost:8080/ws/events

# 운영 모니터링 링크
# 로컬에서는 비워도 /monitor 화면이 localhost port-forward 기본값을 사용합니다.
# 배포 빌드에서는 값이 없으면 버튼이 비활성화됩니다.
REACT_APP_GRAFANA_URL=http://localhost:3000
REACT_APP_PROMETHEUS_URL=http://localhost:9090
REACT_APP_LOKI_URL=
REACT_APP_TEMPO_URL=
